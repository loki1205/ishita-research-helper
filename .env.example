# ─────────────────────────────────────────────
# 👤 USER PROFILE
# ─────────────────────────────────────────────
ABOUT_ME="I am a machine learning researcher interested in foundation models and reasoning"
INTERESTS="large language models, chain of thought reasoning, RLHF, multimodal learning"

# ─────────────────────────────────────────────
# ⚙️ DIGEST SETTINGS
# ─────────────────────────────────────────────
PAPERS_PER_DIGEST=5
DIGEST_FREQUENCY=weekly

# ─────────────────────────────────────────────
# 🤖 LLM CONFIGURATION
# ─────────────────────────────────────────────
# Mode: "smart" (Gemini-powered) or "free" (heuristic, no AI)
MODE=smart

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# 📡 DATA SOURCES
# ─────────────────────────────────────────────
SOURCES=arxiv,semantic_scholar,openalex
INCLUDE_PREPRINTS=true

# ─────────────────────────────────────────────
# 📧 EMAIL CONFIGURATION
# ─────────────────────────────────────────────
EMAIL_PROVIDER=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL="Ishita <your_email@gmail.com>"
TO_EMAIL=recipient@gmail.com
